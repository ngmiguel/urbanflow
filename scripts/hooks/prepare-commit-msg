#!/bin/sh
# Removes Cursor commit attribution trailers injected by IDE agents.
COMMIT_MSG_FILE=$1

if [ -z "$COMMIT_MSG_FILE" ] || [ ! -f "$COMMIT_MSG_FILE" ]; then
  exit 0
fi

if command -v python >/dev/null 2>&1; then
  python - "$COMMIT_MSG_FILE" <<'PY'
import sys

path = sys.argv[1]
with open(path, "r", encoding="utf-8") as handle:
    lines = handle.readlines()

filtered = [
    line for line in lines
    if "co-authored-by: cursor" not in line.lower()
]

with open(path, "w", encoding="utf-8") as handle:
    handle.writelines(filtered)
PY
else
  tmp="${COMMIT_MSG_FILE}.tmp"
  grep -vi "co-authored-by: cursor" "$COMMIT_MSG_FILE" > "$tmp" || true
  mv "$tmp" "$COMMIT_MSG_FILE"
fi
