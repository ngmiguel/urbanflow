# UrbanFlow — Docker Compose environment variables
# Copy to .env in this directory if you need custom values:
#   copy .env.example .env

POSTGRES_USER=urbanflow
POSTGRES_PASSWORD=urbanflow
POSTGRES_DB=postgres
POSTGRES_PORT=5432

REDIS_PORT=6379

KAFKA_PORT=9092
# Inside Docker network, microservices use: kafka:29092
# From host machine (mvn spring-boot:run), use: localhost:9092

# JWT keys are NOT stored here — generate once from repo root:
#   .\scripts\generate-jwt-keys.ps1
# Keys land in secrets/jwt/ and are mounted into auth-service by Docker Compose.
